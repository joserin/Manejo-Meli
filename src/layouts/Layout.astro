---
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css'

interface Props {
	title: string;
}
const { title } = Astro.props;
---  

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body class="flex flex-col sm:flex-row bg-[#0b1120] text-slate-100">
		<Sidebar />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
