---
import Layout from "../layouts/Layout.astro";
import SynchronizationManager from "../components/synchronizer/SynchronizationManager.tsx";
---

<Layout title="Sincronizador de Inventario y Plantillas ML">
    <main class="bg-[#0b1120] min-h-screen text-slate-100 p-4 md:p-8 font-sans w-full flex flex-col items-center">
        
        {/* Contenedor del encabezado */}
        <header class="w-full mb-2 flex flex-col md:flex-row md:items-center justify-between gap-4 pb-2 border-b border-slate-800">
            <div class="flex flex-col gap-1">
                <h1 class="text-xl md:text-3xl font-black tracking-tight flex gap-3 text-white">
                    <span class="p-2 bg-blue-600 rounded-lg shadow-lg shadow-blue-500/20 inline-block">
                        {/* Icono de sincronización representado vectorialmente en CSS limpio */}
                        <div class="w-5 h-5 border-2 border-slate-100 border-t-transparent rounded-full animate-spin-slow"></div>
                    </span>
                    Sincronizador de Listas & Plantillas ML
                </h1>
                <p class="text-slate-400 mt-1 text-xs md:text-sm">
                    Cruza directamente las listas de tus proveedores con la plantilla oficial de Mercado Libre. Actualiza precios finales aplicando tus fórmulas y ajusta stocks en tiempo real en un nuevo archivo descargable.
                </p>
            </div>
        </header>

        {/* Componente Manager de React cargado en el Cliente */}
        <div class="w-full max-w-6xl">
            <SynchronizationManager client:load />
        </div>

    </main>
</Layout>

<style>
    /* Una animación sutil y fluida para el icono superior de carga local */
    .animate-spin-slow {
        animation: spin 4s linear infinite;
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>