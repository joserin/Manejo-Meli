{
	"compatibility_date": "2026-05-28",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "melisync",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
		"binding": "SESSION",
		"id": "d08e5ee109ce418a94a0e0450162c94b"
		}
	]
}